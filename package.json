{
  "name": "paper_reading",
  "version": "1.0.0",
  "description": "Markdown to Marp slides for paper reading.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "marp --server slides",
    "build": "marp \"slides/*.md\" --html --allow-local-files",
    "pdf": "marp \"slides/*.md\" --pdf --allow-local-files",
    "pptx": "marp \"slides/*.md\" --pptx --allow-local-files",
    "start": "npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@marp-team/marp-cli": "^4.3.1"
  }
}
